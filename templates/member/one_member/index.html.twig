{% extends 'base.html.twig' %}

{% block title %}Pet Profile{% endblock %}

{% block body %}

        <main
            class="max-w-6xl mx-auto bg-white shadow-sm  overflow-hidden"
        >
            <!-- BEGIN: Cover Section -->
            <section class="relative" data-purpose="cover-photo-section">
                <div class="h-64 md:h-80 w-full overflow-hidden">
                    <img
                        alt="Cover Photo"
                        class="w-full h-full object-cover"
                        src="{{ asset('assets/images/default_cover.jpg') }}"
                    />
                </div>
            </section>
            <!-- END: Cover Section -->
            <!-- BEGIN: Profile Navigation -->
            <nav
                class="border-b border-gray-100 px-8 py-4 flex flex-wrap gap-6 text-sm font-medium text-gray-500 ml-0 md:ml-72"
                data-purpose="profile-nav"
            >
                <a
                    class="text-(--primary-color) border-b-2 border-(--primary-color) pb-4 -mb-4"
                    href="#"
                    >News</a
                >
                <a class="hover:text-(--primary-color) transition-colors" href="#"
                    >Photos</a
                >
                <a class="hover:text-(--primary-color) transition-colors" href="#"
                    >Videos</a
                >
                <a class="hover:text-(--primary-color) transition-colors" href="#"
                    >Following</a
                >
                <a class="hover:text-(--primary-color) transition-colors" href="#"
                    >Followers</a
                >
                <a class="hover:text-(--primary-color) transition-colors" href="#"
                    >Story</a
                >
                <a class="hover:text-(--primary-color) transition-colors" href="#"
                    >Albums</a
                >
            </nav>
            <!-- END: Profile Navigation -->
            <div class="flex flex-col md:flex-row gap-8 p-8 pt-0">
                <!-- BEGIN: Sidebar Details -->
                <aside
                    class="w-full md:w-64 shrink-0 profile-overlap"
                    data-purpose="pet-sidebar"
                >
                    <!-- Profile Image -->
                    <div class="relative mb-6">
                        <div
                            class="w-48 h-48 rounded-full border-4 border-white shadow-lg overflow-hidden mx-auto md:mx-0"
                        >


                            				{% if pet.profilePictureFileName %}
					<img src="{{ asset('uploads/pets/' ~ pet.profilePictureFileName) }}" alt="{{ pet.name }}" class="h-full w-full object-cover"/>
				{% else %}
					<img src="{{ asset('assets/images/default-pet.png') }}" alt="Pet Photo" class="h-full w-full object-cover opacity-50"/>
				{% endif %}

                        </div>
                    </div>
                    <div class="text-center md:text-left">
                        <h1 class="text-3xl font-bold text-gray-800">
                            {{ pet.name }}
                        </h1>
                        <p
                            class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4"
                        >
                            {{ pet.subtype.name }}
                        </p>
                        <button
                            data-controller="pet-follow"
                            data-action="click->pet-follow#toggle"
                            data-pet-follow-url-value="{{ path('api_pet_follow', { id: pet.id }) }}"
                            data-pet-follow-following-value="{{ isFollowing ? 'true' : 'false' }}"
                            data-pet-follow-follow-class="bg-(--primary-color) hover:bg-[#16a085]"
                            data-pet-follow-following-class="bg-gray-700 hover:bg-gray-600"
                            {% if activePet %}
                                data-pet-follow-follower-id-value="{{ activePet.id }}"
                            {% else %}
                                disabled
                                title="You need at least one pet to follow others."
                            {% endif %}
                            class="cursor-pointer text-white px-6 py-2 rounded-full font-bold text-sm transition-colors shadow-sm uppercase tracking-wide bg-(--primary-color) hover:bg-[#16a085] disabled:opacity-60 disabled:cursor-not-allowed">
                            {{ isFollowing ? 'UNFOLLOW' : 'FOLLOW' }}
                        </button>
                        
                    </div>
                </aside>
                <!-- END: Sidebar Details -->

            </div>
        </main>


{% endblock %}
 